{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
  ],

  // Never rebase open PRs when main is updated — avoids spurious conflicts
  "rebaseWhen": "never",

  customManagers: [
    {
      // Matches the image-versions.yml format:
      //   - name: <depName>
      //     image: <packageName>
      //     tag: <currentValue>
      //     digest: <currentDigest>
      // Note: tag must immediately precede digest (no extra fields in between).
      customType: 'regex',
      description: 'Update container image digests in image-versions.yml',
      managerFilePatterns: ['^image-versions\\.yml$'],
      matchStrings: [
        '- name: (?<depName>[^\\n]+)\\n\\s+image: (?<packageName>[^\\n]+)\\n\\s+tag: ["\']?(?<currentValue>[^\\n"\']+)["\']?\\n\\s+digest: (?<currentDigest>sha256:[a-f0-9]+)',
      ],
      datasourceTemplate: 'docker',
    },
  ],

  "packageRules": [
    {
      // Auto-merge all digest-only bumps in image-versions.yml.
      // These are low-risk: same tag, same content, just refreshed layers.
      "description": "Auto-merge digest updates in image-versions.yml",
      "automerge": true,
      "matchManagers": ["custom.regex"],
      "matchUpdateTypes": ["digest", "pinDigest"],
      "matchFileNames": ["image-versions.yml"],
      "labels": ["renovate", "automerge"],
    },
    {
      // Group bluefin base image updates together so they land as one PR.
      // All four share the same upstream release cadence.
      "description": "Group Bluefin base image digest bumps",
      "groupName": "Bluefin base images",
      "matchDepNames": ["bluefin", "bluefin-dx", "bluefin-nvidia-open", "bluefin-dx-nvidia-open"],
      "matchFileNames": ["image-versions.yml"],
    },
    {
      // Group akmods updates together. akmods-main (MOK key) and akmods-nvidia-lts-main
      // (driver modules) track the same Fedora release and should bump atomically.
      "description": "Group akmods image digest bumps",
      "groupName": "akmods images",
      "matchDepNames": ["akmods-main", "akmods-nvidia-lts-main"],
      "matchFileNames": ["image-versions.yml"],
    },
    {
      // Keep GitHub Actions pinned by SHA up to date
      "description": "Update GitHub Actions to latest SHA pins",
      "enabled": true,
      "matchUpdateTypes": ["digest", "pinDigest", "pin", "major", "minor", "patch"],
      "matchDepTypes": ["action"],
      "matchFileNames": [".github/workflows/**.yml"],
      "labels": ["renovate"],
    },
  ],
}
