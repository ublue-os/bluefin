{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "labels": ["renovate"],
  "rebaseWhen": "conflicted",
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/ublue-os/bluefin",
        "ghcr.io/ublue-os/bluefin-dx",
        "ghcr.io/ublue-os/bluefin-nvidia-open",
        "ghcr.io/ublue-os/bluefin-dx-nvidia-open"
      ],
      "groupName": "bluefin base images",
      "groupSlug": "bluefin-base",
      "commitMessageTopic": "Bluefin base images"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/ublue-os/akmods",
        "ghcr.io/ublue-os/akmods-nvidia-lts"
      ],
      "groupName": "akmods images",
      "groupSlug": "akmods",
      "commitMessageTopic": "akmods"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update image digests in image-versions.yml",
      "fileMatch": ["^image-versions\\.yml$"],
      "matchStrings": [
        "depName=(?<depName>[^\\s]+)[^\\n]*\\n\\s+digest:\\s+(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ]
}
